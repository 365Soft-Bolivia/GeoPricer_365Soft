# ==============================================================================
# PLANTILLA DE PRODUCCIÓN — Copiar como .env en el VPS
# cp .env.production.example .env
# ==============================================================================

# ─── Aplicación ───────────────────────────────────────────────────────────────
APP_NAME=GeoPricer
APP_ENV=production
APP_KEY=                              # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://acmanalytics.online

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Base de datos ────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=acmanalytics
DB_USERNAME=acmanalytics
DB_PASSWORD=                          # contraseña segura (mínimo 16 caracteres)
DB_ROOT_PASSWORD=                     # contraseña root diferente a la anterior

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                       # contraseña para redis

# ─── Cache, Sesiones y Queue ──────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=redis

# ─── Broadcast / Filesystem ───────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Correo ───────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=                            # smtp.tuproveedor.com
MAIL_PORT=587
MAIL_USERNAME=                        # correo@tu-dominio.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@acmanalytics.online
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS S3 (opcional) ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Vite (solo referencia, no aplica en producción) ─────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─── Docker Compose ───────────────────────────────────────────────────────────
MYSQL_PORT=3307                       # puerto externo MySQL (3306 puede estar ocupado en VPS)

# ─── Aplicación ───────────────────────────────────────────────────────────────
APP_NAME="GeoPricer"
APP_ENV=production
APP_KEY=                        # Generar con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://tu-dominio.com
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# ─── Base de datos ────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql                   # Nombre del servicio en docker-compose
DB_PORT=3306
DB_DATABASE=geopricer
DB_USERNAME=geopricer
DB_PASSWORD=cambia_esta_contrasena_segura

# ─── MySQL root (solo para docker-compose healthcheck) ────────────────────────
DB_ROOT_PASSWORD=cambia_esta_contrasena_root

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis                # Nombre del servicio en docker-compose
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─── Cache, Sesiones y Queue (Redis en producción) ────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ─── Correo ───────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.tu-proveedor.com
MAIL_PORT=587
MAIL_USERNAME=correo@tu-dominio.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@tu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Almacenamiento ───────────────────────────────────────────────────────────
FILESYSTEM_DISK=local           # Cambiar a 's3' si usas AWS S3

# ─── Puerto expuesto del contenedor nginx (en el host) ────────────────────────
APP_PORT=80
MYSQL_PORT=3306                 # Cambiar si 3306 está ocupado en el host

# ─── Seguridad ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
SESSION_ENCRYPT=true
